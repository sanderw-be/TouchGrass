{
  "expo": {
    "name": "TouchGrass",
    "slug": "touchgrass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F9F7"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A7C59"
      },
      "package": "com.yourname.touchgrass",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TouchGrass needs background location to detect when you go outside.",
          "locationAlwaysPermission": "TouchGrass needs background location to detect when you go outside.",
          "locationWhenInUsePermission": "TouchGrass needs location to detect when you go outside."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A7C59"
        }
      ],
      "react-native-health-connect",
      "expo-sqlite",
      "expo-background-task",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "34928510-f2c8-47b0-9d37-c911af91d506"
      }
    },
    "owner": "wubbewubben"
  }
}
