{
  "expo": {
    "name": "TouchGrass",
    "slug": "touchgrass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F9F7"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A7C59"
      },
      "package": "com.sanderwubben.touchgrass",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_STEPS",
       "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_DISTANCE"
      ]
    },
    "plugins": [
      "expo-calendar",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TouchGrass needs background location to detect when you go outside.",
          "locationAlwaysPermission": "TouchGrass needs background location to detect when you go outside.",
          "locationWhenInUsePermission": "TouchGrass needs location to detect when you go outside."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A7C59"
        }
      ],
      [
        "./withAbiFilters",
        {
          "abiFilters": [
            "arm64-v8a"
          ]
        }
      ],
  [
  "expo-build-properties",
  {
    "android": {
      "minSdkVersion": 26,
      "buildArchs": ["arm64-v8a"],
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "extraProguardRules": "-keep class expo.modules.adapters.react.apploader.RNHeadlessAppLoader { *; }\n-keep interface expo.modules.apploader.HeadlessAppLoader { *; }\n-keep class expo.modules.apploader.AppLoaderProvider { *; }\n-keep class expo.modules.calendar.** { *; }",
      "manifestQueries": {
        "intents": [
          {
            "action": "androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE"
          },
          {
            "action": "android.settings.HEALTH_CONNECT_SETTINGS"
          },
          {
            "action": "android.health.connect.action.MANAGE_HEALTH_PERMISSIONS"
          },
          {
            "action": "android.health.connect.action.HEALTH_HOME_SETTINGS"
          }
        ]
      },
      "queries": [
        {
          "package": "com.google.android.apps.healthdata"
        }
      ]
    }
  }
      ],
      "expo-health-connect",
      "expo-sqlite",
      "expo-background-task",
      "expo-localization",
      "expo-system-ui"
    ],
    "extra": {
      "eas": {
        "projectId": "34928510-f2c8-47b0-9d37-c911af91d506"
      }
    },
    "owner": "wubbewubben",
    "ios": {
      "bundleIdentifier": "com.sanderwubben.touchgrass",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    }
  }
}
