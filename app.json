{
  "expo": {
    "name": "TouchGrass",
    "slug": "touchgrass",
    // This version is a placeholder. The actual version is set dynamically
    // in app.config.js from the `version` field in package.json.
    "version": "1.0.0",
    "scheme": "touchgrass",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F9F7"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4A7C59"
      },
      "package": "com.jollyheron.touchgrass",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_STEPS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "plugins": [
      "expo-calendar",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TouchGrass uses background location to automatically detect outdoor sessions via geofencing. Approximate location is also used for local weather conditions when weather-aware reminders are enabled.",
          "locationAlwaysPermission": "TouchGrass uses background location to automatically detect outdoor sessions via geofencing (detecting when you leave and return to known indoor places like home or work).",
          "locationWhenInUsePermission": "TouchGrass uses your location for outdoor session detection and to fetch local weather conditions for weather-aware reminders."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A7C59"
        }
      ],
      [
        "./withAbiFilters",
        {
          "abiFilters": ["arm64-v8a"]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26,
            "buildArchs": ["arm64-v8a"],
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "extraProguardRules": "-keep class expo.modules.adapters.react.apploader.RNHeadlessAppLoader { *; }\n-keep interface expo.modules.apploader.HeadlessAppLoader { *; }\n-keep class expo.modules.apploader.AppLoaderProvider { *; }\n-keep class expo.modules.calendar.** { *; }\n-keep class com.reactnativeandroidwidget.** { *; }",
            "manifestQueries": {
              "intents": [
                {
                  "action": "androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE"
                },
                {
                  "action": "android.settings.HEALTH_CONNECT_SETTINGS"
                },
                {
                  "action": "android.health.connect.action.MANAGE_HEALTH_PERMISSIONS"
                },
                {
                  "action": "android.health.connect.action.HEALTH_HOME_SETTINGS"
                }
              ]
            },
            "queries": [
              {
                "package": "com.google.android.apps.healthdata"
              }
            ],
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      "expo-health-connect",
      "expo-sqlite",
      "expo-background-task",
      "expo-localization",
      "expo-system-ui",
      "expo-font",
      "./withAlarmBridgePlugin",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "Progress",
              "label": "TouchGrass Progress",
              "description": "Shows your daily outdoor progress and a quick timer",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "previewImage": "./assets/widget-preview.png",
              "updatePeriodMillis": 1800000,
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "34928510-f2c8-47b0-9d37-c911af91d506"
      },
      "privacyPolicyUrl": "https://sanderw-be.github.io/TouchGrass-Legal/privacy-policy.html"
    },
    "owner": "wubbewubben",
    "ios": {
      "bundleIdentifier": "com.jollyheron.touchgrass",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/34928510-f2c8-47b0-9d37-c911af91d506",
      "fallbackToCacheTimeout": 3000
    }
  }
}
